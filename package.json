{
  "name": "vite-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "buildServer": "tsc -b ./tsconfig.server.json",
    "buildAndRunServer": "tsc -b ./tsconfig.server.json && npm run serve",
    "buildApp": "tsc -b && vite build",
    "build": "npm run buildApp && npm run buildServer",
    "preview": "vite preview",
    "serve": "node dist/server/server.js",
    "verify": "node e2e/verify-multi-move.mjs && node e2e/verify-block-reconnect.mjs && node e2e/verify-other-player-connection.mjs && node e2e/verify-reconnect-given-up.mjs",
    "deploy": "git push heroku main",
    "lint": "eslint .",
    "type-check": "tsc -b --noEmit",
    "validate": "npm run type-check && npm run lint",
    "knip": "knip",
    "format": "prettier --write \"{client,server,shared}/**/*.{ts,tsx}\"",
    "heroku:off": "heroku ps:scale web=0 --app richards-board-games",
    "heroku:on": "heroku ps:scale web=1 --app richards-board-games",
    "heroku:restart": "heroku restart --app richards-board-games"
  },
  "engines": {
    "node": "22.x",
    "npm": "11.x"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "qs": "^6.15.2",
    "rdndmb-html5-to-touch": "^9.0.0",
    "react": "^19.0.0",
    "react-async-hook": "^4.0.0",
    "react-dnd": "^16.0.1",
    "react-dnd-multi-backend": "^9.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^5.0.0",
    "react-router-dom": "^7.5.0",
    "react-use-websocket": "^4.13.0",
    "styled-components": "^6.1.17",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/qs": "^6.15.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "knip": "^6.16.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  }
}
